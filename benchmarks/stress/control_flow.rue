fn while_complex_01() -> i32 {
    let mut sum = 0;
    let mut i = 0;
    while i < 51 {
        if i % 2 == 0 {
            sum = sum + i;
        } else if i % 3 == 0 {
            sum = sum - i / 3;
        } else if i % 5 == 0 {
            sum = sum + 1;
        } else {
            sum = sum + 1;
        }
        i = i + 1;
    }
    sum
}

