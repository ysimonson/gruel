fn complex_branch_01(a: i32, b: i32) -> i32 {
    if a > 0 {
        if b > 0 {
            if a > b {
                a * b + 1
            } else {
                b * a - 1
            }
        } else {
            if a > 0 - b {
                a - b + 1
            } else {
                b - a + 2
            }
        }
    } else {
        if b > 0 {
            b + 1
        } else {
            0 - a - b + 1
        }
    }
}

