fn nested_loops_01() -> i32 {
    let mut total = 0;
    let mut i = 0;
    while i < 11 {
        let mut j = 0;
        while j < 9 {
            if i * j > 10 {
                total = total + i * j;
            } else {
                total = total + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    total
}

