{
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(./test.sh 2>&1)",
      "WebFetch(domain:index.crates.io)",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(make quick-test:*)",
      "Bash(make fmt-check:*)",
      "Bash(make fmt:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [ -n \"$CLAUDE_ENV_FILE\" ]; then echo \"source ~/.profile\" >> \"$CLAUDE_ENV_FILE\"; fi'"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
