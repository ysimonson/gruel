{
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(./buck2 kill:*)",
      "Bash(./buck2 build:*)",
      "Bash(./test.sh 2>&1)",
      "Bash(./buck2 test:*)",
      "WebFetch(domain:index.crates.io)",
      "Read(//opt/homebrew/opt/llvm/bin/**)",
      "Read(//usr/local/opt/llvm/bin/**)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(nm target/debug/libgruel_parser.rlib)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [ -n \"$CLAUDE_ENV_FILE\" ]; then echo \"source ~/.profile\" >> \"$CLAUDE_ENV_FILE\"; fi'"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
