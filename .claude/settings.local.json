{
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(./buck2 kill:*)",
      "Bash(./buck2 build:*)",
      "Bash(./test.sh 2>&1)",
      "Bash(./buck2 test:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [ -n \"$CLAUDE_ENV_FILE\" ]; then echo \"source ~/.profile\" >> \"$CLAUDE_ENV_FILE\"; fi'"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
