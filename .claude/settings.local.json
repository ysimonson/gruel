{
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(./test.sh 2>&1)",
      "WebFetch(domain:index.crates.io)",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo run:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(make quick-test:*)",
      "Bash(make fmt-check:*)",
      "Bash(make fmt:*)",
      "Bash(printf:*)",
      "Bash(cat:*)",
      "WebSearch",
      "Skill(code-review)",
      "Skill(commit)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gruel.yusufsimonson.com)",
      "Bash(echo \"exit=$?\")",
      "Skill(update-config)",
      "Bash(./scratch/*)",
      "Skill(design-adr)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "make check",
            "if": "Bash(git commit*)",
            "timeout": 120,
            "statusMessage": "Running make check..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [ -n \"$CLAUDE_ENV_FILE\" ]; then echo \"source ~/.profile\" >> \"$CLAUDE_ENV_FILE\"; fi'"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
